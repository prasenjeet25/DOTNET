@model List<Exp8.Models.Student>

<h2>Student List</h2>

<a href="/Student/Create">Add Student</a>

<table border="1">
<tr>
<th>Name</th>
<th>Age</th>
<th>Action</th>
</tr>

@foreach (var s in Model)
{
<tr>
<td>@s.Name</td>
<td>@s.Age</td>
<td><a href="/Student/Delete/@s.Id">Delete</a></td>
</tr>
}
</table>